#!/usr/bin/env bash

# Remove stale server.pid if it exists
PID_FILE="tmp/pids/server.pid"
if [ -f "$PID_FILE" ]; then
  echo "Removing stale server.pid..."
  rm "$PID_FILE"
fi

# Kill process on port 3000 if running
PORT=3000
PID=$(lsof -ti tcp:$PORT)
if [ -n "$PID" ]; then
  echo "Port $PORT is in use by PID $PID, killing it..."
  kill -9 $PID
else
  echo "Port $PORT is free."
fi

# Kill process on port 3036 if running
VITE_PORT=3036
VITE_PID=$(lsof -ti tcp:$VITE_PORT)
if [ -n "$VITE_PID" ]; then
  echo "Port $VITE_PORT is in use by PID $VITE_PID, killing it..."
  kill -9 $VITE_PID
else
  echo "Port $VITE_PORT is free."
fi

# Start Rails and Vite dev servers
echo "Starting Rails + Vite dev servers..."

# Use foreman or concurrently to manage both processes
exec bin/rails server -p 3000 & bin/vite dev & wait
